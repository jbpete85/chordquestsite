---
import BaseLayout from '../layouts/BaseLayout.astro';
import FaqAccordion from '../components/FaqAccordion.astro';

const base = import.meta.env.BASE_URL;

const faqItems = [
  {
    question: 'What is ChordQuest?',
    answer: 'ChordQuest is an interactive music learning app that turns physical sheet music into playable audio. Snap a photo or upload a score to hear your part, control tempo, and practice with confidence.',
  },
  {
    question: 'Does it work with any sheet music?',
    answer: 'ChordQuest works best with clearly printed, standard notation. Clean PDFs produce the most accurate results. Handwritten music or low-quality photos may reduce accuracy.',
  },
  {
    question: 'Can I isolate just my part?',
    answer: 'Yes. You can mute and hear staves independently. True individual part isolation is on our development roadmap.',
  },
  {
    question: 'Is this meant to replace lessons?',
    answer: 'No. ChordQuest supports teachers by reinforcing productive practice between lessons, helping students practice more independently.',
  },
];
---
<BaseLayout>
  <!-- ===== HERO ===== -->
  <section class="hero">
    <div class="container hero__inner">
      <div class="hero__content">
        <p class="eyebrow">For Music Teachers &amp; Students &middot; iOS &middot; Free Download</p>
        <h1 class="headline-xl hero__headline">Any Sheet Music.<br/>Any Instrument.<br/>Hear And Play Back Instantly.</h1>
        <p class="body-lg hero__sub">Upload or snap a pic of any piece of sheet music. ChordQuest reads the notes and plays back your exact part in seconds&nbsp;&mdash; no library to search, no instrument limitations, no guessing how it goes.</p>
        <div class="hero__ctas">
          <a href="https://app.chordquestmusic.com" class="btn btn--gold">Get Started Free</a>
          <a href="#how-it-works" class="btn btn--outline">Watch It Work &rarr;</a>
        </div>
      </div>
      <div class="hero__mockup">
        <div class="hero__shape hero__shape--1"></div>
        <div class="hero__shape hero__shape--2"></div>
        <div class="hero__shape hero__shape--3"></div>
        <img src={`${base}images/iphone-mockup.png`} alt="ChordQuest app on iPhone 17 Pro showing sheet music playback" class="hero__device" />
      </div>
    </div>
  </section>

  <!-- ===== SOCIAL PROOF BAR ===== -->
  <section class="social-proof">
    <div class="container social-proof__inner">
      <span>&starf;&starf;&starf;&starf;&starf; Recommended by private teachers</span>
      <span class="social-proof__divider"></span>
      <span>Free for teachers</span>
      <span class="social-proof__divider"></span>
      <span>iOS &middot; iPhone &amp; iPad</span>
      <span class="social-proof__divider"></span>
      <span>Piano &middot; Guitar &middot; More coming</span>
    </div>
  </section>

  <!-- ===== ENTITY BLOCK ===== -->
  <section class="entity">
    <div class="container container--narrow">
      <p class="entity__text">ChordQuest is a free app for music students and teachers that turns any photo of sheet music into instant playback. Students hear their exact part&nbsp;&mdash; on any instrument&nbsp;&mdash; before they practice it. Free for teachers forever. Student subscriptions are free for the first 7 days, then only $4.99/month after.</p>
    </div>
  </section>

  <!-- ===== HOW IT WORKS ===== -->
  <section class="how-it-works section" id="how-it-works">
    <div class="container">
      <div class="how-it-works__header">
        <p class="eyebrow">How It Works</p>
        <h2 class="headline-lg">Capture The Music.<br/>Master Your Part.</h2>
        <p class="body-lg text-warm how-it-works__sub">No more searching libraries, hoping to find the song and instrument you need. ChordQuest reads directly from your sheet music. Any publisher, any edition.</p>
      </div>

      <div class="steps-interactive">
        <!-- Step 1 -->
        <div class="step-row reveal">
          <div class="step-tile">
            <div class="step-tile__text">
              <div class="step-tile__heading">
                <span class="step-tile__num">1</span>
                <h3 class="step-tile__title">Point Your Camera</h3>
              </div>
              <p class="step-tile__body">Scan or upload any piece of music you're working on.</p>
            </div>
            <div class="step-tile__visual">
              <img src={`${base}images/justiphone.png`} alt="iPhone camera scanning sheet music" class="step-tile__photo" />
            </div>
          </div>
        </div>

        <!-- Step 2 -->
        <div class="step-row step-row--reverse reveal">
          <div class="step-tile">
            <div class="step-tile__text">
              <div class="step-tile__heading">
                <span class="step-tile__num">2</span>
                <h3 class="step-tile__title">It Reads Every Note</h3>
              </div>
              <p class="step-tile__body">ChordQuest reads every note–directly from the music.</p>
            </div>
            <div class="step-tile__visual">
              <div class="device-macbook">
                <video class="device-macbook__screen" muted playsinline preload="metadata" data-play-once>
                  <source src={`${base}images/processing-success-clip.mp4`} type="video/mp4" />
                </video>
                <img src={`${base}images/macbook-bezel.png`} alt="" class="device-macbook__bezel" aria-hidden="true" />
              </div>
            </div>
          </div>
        </div>

        <!-- Step 3 -->
        <div class="step-row reveal">
          <div class="step-tile">
            <div class="step-tile__text">
              <div class="step-tile__heading">
                <span class="step-tile__num">3</span>
                <h3 class="step-tile__title">Hear the Exact Part</h3>
              </div>
              <p class="step-tile__body">Hear your notes isolated or as part of the full ensemble.</p>
            </div>
            <div class="step-tile__visual">
              <div class="device-ipad">
                <video class="device-ipad__screen" muted playsinline preload="metadata" data-play-once>
                  <source src={`${base}images/playthrough-clip.mp4`} type="video/mp4" />
                </video>
                <img src={`${base}images/ipad-bezel.png`} alt="" class="device-ipad__bezel" aria-hidden="true" />
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <script>
    // Reveal on scroll
    const revealEls = document.querySelectorAll('.reveal');
    if (revealEls.length > 0) {
      const revealObserver = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add('visible');
              revealObserver.unobserve(entry.target);
            }
          });
        },
        { threshold: 0.12 }
      );
      revealEls.forEach((el) => revealObserver.observe(el));
    }

    // Play videos once on reveal
    const playOnceVideos = document.querySelectorAll('video[data-play-once]');
    if (playOnceVideos.length > 0) {
      const videoObserver = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              const video = entry.target;
              video.play().catch(() => {});
              videoObserver.unobserve(video);
            }
          });
        },
        { threshold: 0.3 }
      );
      playOnceVideos.forEach((video) => videoObserver.observe(video));
    }
  </script>

  <!-- ===== FOR TEACHERS STRIP ===== -->
  <section class="teachers-strip section">
    <div class="container">
      <div class="teachers-strip__content">
        <p class="eyebrow">For Teachers</p>
        <h2 class="headline-lg teachers-strip__headline">The between-lesson practice tool music teachers recommend.</h2>
        <p class="body-lg teachers-strip__body">Give every student in your class instant playback of their exact part using the sheet music they already own. They come prepared, letting you teach the perfect lesson!</p>
        <a href={`${base}teachers`} class="btn btn--gold">Teachers Download Free</a>
      </div>
      <div class="teachers-strip__mockup">
        <img src={`${base}images/Product%20Shot.png`} alt="ChordQuest app product screenshot" class="teachers-strip__product-shot" />
      </div>
    </div>
  </section>

  <!-- ===== FOR PARENTS STRIP ===== -->
  <section class="parents-strip section">
    <div class="container parents-strip__inner">
      <div class="parents-strip__decor">
        <div class="parents-strip__graphic">
          <svg viewBox="0 0 200 280" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <line x1="20" y1="60" x2="180" y2="60" stroke="#C8924A" stroke-opacity="0.15" stroke-width="1"/>
            <line x1="20" y1="75" x2="180" y2="75" stroke="#C8924A" stroke-opacity="0.15" stroke-width="1"/>
            <line x1="20" y1="90" x2="180" y2="90" stroke="#C8924A" stroke-opacity="0.15" stroke-width="1"/>
            <line x1="20" y1="105" x2="180" y2="105" stroke="#C8924A" stroke-opacity="0.15" stroke-width="1"/>
            <line x1="20" y1="120" x2="180" y2="120" stroke="#C8924A" stroke-opacity="0.15" stroke-width="1"/>
            <circle cx="70" cy="82" r="6" fill="#C8924A" fill-opacity="0.12"/>
            <circle cx="110" cy="97" r="6" fill="#C8924A" fill-opacity="0.12"/>
            <circle cx="140" cy="67" r="6" fill="#C8924A" fill-opacity="0.12"/>
            <line x1="20" y1="170" x2="180" y2="170" stroke="#C8924A" stroke-opacity="0.1" stroke-width="1"/>
            <line x1="20" y1="185" x2="180" y2="185" stroke="#C8924A" stroke-opacity="0.1" stroke-width="1"/>
            <line x1="20" y1="200" x2="180" y2="200" stroke="#C8924A" stroke-opacity="0.1" stroke-width="1"/>
            <line x1="20" y1="215" x2="180" y2="215" stroke="#C8924A" stroke-opacity="0.1" stroke-width="1"/>
            <line x1="20" y1="230" x2="180" y2="230" stroke="#C8924A" stroke-opacity="0.1" stroke-width="1"/>
          </svg>
        </div>
      </div>
      <div class="parents-strip__content">
        <p class="eyebrow">For Parents</p>
        <h2 class="headline-lg">No Music Background? No Time?<br/>No Problem.</h2>
        <p class="body-lg text-warm">When students know what their part should sound like, learning music becomes more productive, and far less frustrating. With ChordQuest's sheet music playback technology, parents can confidently support their child's practice without preparation or needing to know how to read a single note.</p>
        <p class="body-lg text-warm parents-strip__note">One subscription for $4.99 covers the whole family too.</p>
        <a href={`${base}parents`} class="btn btn--gold">Try For Free</a>
      </div>
    </div>
  </section>

  <!-- ===== FAQ ===== -->
  <section class="faq section--sm" id="faq">
    <div class="container container--narrow">
      <h2 class="headline-md faq__headline">Frequently Asked Questions</h2>
      <FaqAccordion items={faqItems} />
    </div>
  </section>

  <!-- ===== FINAL CTA ===== -->
  <section class="final-cta section">
    <div class="final-cta__lines" aria-hidden="true">
      <span></span><span></span><span></span><span></span><span></span>
    </div>
    <div class="container container--narrow final-cta__inner">
      <h2 class="headline-lg final-cta__headline">The difference between a student who practiced and one who didn't is obvious the second they sit down.</h2>
      <p class="body-lg final-cta__sub">Every student deserves to walk in prepared. Every teacher deserves to teach the good stuff.</p>
    </div>
  </section>
</BaseLayout>

<style>
  /* ===== HERO ===== */
  .hero {
    background-color: var(--color-dark);
    padding: 80px 0 96px;
    overflow: hidden;
  }
  .hero__inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 64px;
    align-items: center;
  }
  .hero__headline {
    color: var(--color-cream);
    margin-bottom: 24px;
  }
  .hero__sub {
    color: var(--color-text-muted);
    margin-bottom: 36px;
    max-width: 520px;
  }
  .hero__ctas {
    display: flex;
    gap: 16px;
    flex-wrap: wrap;
  }
  .hero__mockup {
    display: flex;
    justify-content: center;
    align-items: center;
    position: relative;
  }
  .hero__shape {
    position: absolute;
    border-radius: 32px;
    z-index: 0;
  }
  .hero__shape--1 {
    width: 320px;
    height: 380px;
    background-color: #C8924A;
    opacity: 0.25;
    top: -20px;
    right: -60px;
    transform: rotate(-8deg);
    animation: float-1 8s ease-in-out infinite;
  }
  .hero__shape--2 {
    width: 220px;
    height: 280px;
    background-color: #D9B077;
    opacity: 0.18;
    bottom: 20px;
    left: -40px;
    border-radius: 40px;
    transform: rotate(12deg);
    animation: float-2 10s ease-in-out infinite;
  }
  .hero__shape--3 {
    width: 140px;
    height: 140px;
    background-color: #C8924A;
    opacity: 0.12;
    top: 60%;
    right: 10%;
    border-radius: 50%;
    animation: float-3 6s ease-in-out infinite;
  }
  @keyframes float-1 {
    0%, 100% { transform: rotate(-8deg) translateY(0); }
    50% { transform: rotate(-6deg) translateY(-14px); }
  }
  @keyframes float-2 {
    0%, 100% { transform: rotate(12deg) translateX(0); }
    50% { transform: rotate(10deg) translateX(10px) translateY(-8px); }
  }
  @keyframes float-3 {
    0%, 100% { transform: scale(1) translateY(0); }
    50% { transform: scale(1.08) translateY(-10px); }
  }
  .hero__device {
    position: relative;
    z-index: 1;
    width: 100%;
    max-width: 280px;
    height: auto;
    filter: drop-shadow(0 20px 60px rgba(0,0,0,0.4));
  }

  /* ===== SOCIAL PROOF ===== */
  .social-proof {
    background-color: var(--color-social-proof-bg);
    padding: 18px 0;
  }
  .social-proof__inner {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 24px;
    flex-wrap: wrap;
    font-size: 13px;
    font-weight: 500;
    color: var(--color-text-muted);
  }
  .social-proof__divider {
    width: 1px;
    height: 14px;
    background-color: rgba(200, 146, 74, 0.2);
  }

  /* ===== ENTITY ===== */
  .entity {
    background-color: var(--color-dark);
    padding: 64px 0;
  }
  .entity__text {
    text-align: center;
    font-size: 15px;
    line-height: 1.8;
    color: var(--color-text-muted);
    max-width: 740px;
    margin: 0 auto;
  }

  /* ===== HOW IT WORKS ===== */
  .how-it-works {
    background-color: var(--color-cream);
  }
  .how-it-works__header {
    text-align: center;
    max-width: 640px;
    margin: 0 auto 64px;
  }
  .how-it-works__sub {
    margin-top: 20px;
  }

  /* --- Interactive Steps --- */
  .steps-interactive {
    display: flex;
    flex-direction: column;
    gap: 88px;
    max-width: 1100px;
    margin: 0 auto;
  }
  .step-row {
    display: flex;
    justify-content: center;
    overflow: visible;
  }
  .step-tile {
    width: 100%;
    padding: 24px 44px;
    background-color: var(--color-dark);
    border-radius: 20px;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 40px;
    align-items: center;
    overflow: visible;
    height: 260px;
    box-sizing: border-box;
    position: relative;
  }
  .step-row--reverse .step-tile {
    direction: rtl;
  }
  .step-row--reverse .step-tile > * {
    direction: ltr;
  }
  .step-tile__text {
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-self: center;
  }
  .step-tile__heading {
    display: flex;
    align-items: center;
    gap: 16px;
    margin-bottom: 16px;
  }
  .step-tile__num {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    border-radius: 50%;
    background-color: var(--color-gold);
    color: var(--color-dark);
    font-family: var(--font-body);
    font-size: 16px;
    font-weight: 700;
    flex-shrink: 0;
  }
  .step-tile__title {
    font-family: var(--font-headline);
    font-size: 36px;
    color: var(--color-cream);
    line-height: 1.2;
  }
  .step-tile__body {
    font-size: 20px;
    line-height: 1.7;
    color: var(--color-text-muted);
    max-width: 48ch;
    white-space: nowrap;
  }
  .step-tile__visual {
    display: flex;
    justify-content: center;
    align-items: center;
    overflow: visible;
    position: relative;
    align-self: center;
    height: 0;
  }
  .step-tile::before {
    content: '';
    position: absolute;
    background: var(--color-gold);
    z-index: 1;
    pointer-events: none;
  }
  .step-tile__text,
  .step-tile__visual {
    position: relative;
    z-index: 2;
  }
  .step-row:nth-child(1) .step-tile::before {
    width: 275px;
    height: 253px;
    border-radius: 62% 38% 46% 54% / 60% 44% 56% 40%;
    right: 16%;
    top: -10px;
  }
  .step-row:nth-child(2) .step-tile::before {
    width: 380px;
    height: 340px;
    border-radius: 44% 56% 35% 65% / 55% 40% 60% 45%;
    left: 5%;
    top: -50px;
  }
  .step-row:nth-child(3) .step-tile::before {
    width: 340px;
    height: 320px;
    border-radius: 55% 45% 60% 40% / 38% 62% 38% 62%;
    right: 15%;
    top: -30px;
  }
  .step-tile__photo {
    max-width: 170px;
    height: auto;
    border-radius: 24px;
    filter: drop-shadow(0 16px 40px rgba(0,0,0,0.3));
    margin: -30px 0;
    position: relative;
    z-index: 1;
  }

  /* Device: MacBook */
  .device-macbook {
    position: relative;
    width: 110%;
    max-width: 620px;
    margin: -60px -5% -30px;
    z-index: 1;
  }
  .device-macbook__bezel {
    position: relative;
    width: 100%;
    height: auto;
    display: block;
    z-index: 2;
    pointer-events: none;
  }
  .device-macbook__screen {
    position: absolute;
    z-index: 1;
    top: 10.5%;
    left: 11.5%;
    width: 77%;
    height: 80%;
    object-fit: cover;
    object-position: left top;
    border-radius: 4px;
    background: #1a1a1a;
  }

  /* Device: iPad */
  .device-ipad {
    position: relative;
    width: 90%;
    max-width: 520px;
    overflow: hidden;
    margin: -30px 0;
    z-index: 1;
  }
  .device-ipad__bezel {
    position: relative;
    width: 100%;
    height: auto;
    display: block;
    z-index: 2;
    pointer-events: none;
  }
  .device-ipad__screen {
    position: absolute;
    z-index: 1;
    top: 4%;
    left: 4.5%;
    width: 91%;
    height: 92.5%;
    object-fit: cover;
    object-position: center bottom;
    border-radius: 10px;
    background: #1a1a1a;
  }

  /* Reveal animation */
  .reveal {
    opacity: 0;
    transform: translateY(24px);
    transition: opacity 0.6s ease, transform 0.6s ease;
  }
  .reveal.visible {
    opacity: 1;
    transform: translateY(0);
  }

  /* Cascaded step reveals */
  .step-row .step-tile__text {
    opacity: 0;
    transform: translateY(12px);
    transition: opacity 0.5s ease, transform 0.5s ease;
  }
  .step-row .step-tile::before {
    opacity: 0;
    transform: scale(0.8);
    transition: opacity 0.5s ease 0.15s, transform 0.5s ease 0.15s;
  }
  .step-row .step-tile__visual {
    opacity: 0;
    transform: translateY(12px);
    transition: opacity 0.5s ease 0.2s, transform 0.5s ease 0.2s;
  }
  .step-row.visible .step-tile__text {
    opacity: 1;
    transform: translateY(0);
  }
  .step-row.visible .step-tile::before {
    opacity: 1;
    transform: scale(1);
  }
  .step-row.visible .step-tile__visual {
    opacity: 1;
    transform: translateY(0);
  }

  /* ===== FOR TEACHERS STRIP ===== */
  .teachers-strip {
    background-color: var(--color-dark);
  }
  .teachers-strip .container {
    text-align: center;
    max-width: 720px;
  }
  .teachers-strip__headline {
    color: var(--color-cream);
    margin-bottom: 20px;
  }
  .teachers-strip__body {
    color: var(--color-text-muted);
    margin-bottom: 32px;
  }
  .teachers-strip__mockup {
    margin-top: 64px;
    display: flex;
    justify-content: center;
  }
  .teachers-strip__product-shot {
    width: 100%;
    max-width: 600px;
    height: auto;
    border-radius: 16px;
    border: 2px solid rgba(200, 146, 74, 0.3);
    box-shadow: 0 8px 40px rgba(200, 146, 74, 0.15), 0 0 0 1px rgba(200, 146, 74, 0.08);
  }

  /* ===== FOR PARENTS STRIP ===== */
  .parents-strip {
    background-color: var(--color-card-bg);
  }
  .parents-strip__inner {
    display: grid;
    grid-template-columns: 280px 1fr;
    gap: 64px;
    align-items: start;
  }
  .parents-strip__decor {
    position: relative;
  }
  .parents-strip__graphic {
    width: 100%;
    max-width: 200px;
    opacity: 0.8;
  }
  .parents-strip__graphic svg {
    width: 100%;
    height: auto;
  }
  .parents-strip__content {
    max-width: 600px;
  }
  .parents-strip__content .headline-lg {
    margin-bottom: 24px;
  }
  .parents-strip__content .body-lg {
    margin-bottom: 16px;
  }
  .parents-strip__note {
    font-weight: 600;
    margin-bottom: 32px !important;
  }

  /* ===== FAQ ===== */
  .faq {
    background-color: var(--color-card-bg);
    padding-bottom: 96px;
  }
  .faq__headline {
    margin-bottom: 40px;
  }

  /* ===== FINAL CTA ===== */
  .final-cta {
    background-color: var(--color-dark);
    position: relative;
    overflow: hidden;
  }
  .final-cta__lines {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 15px;
    pointer-events: none;
  }
  .final-cta__lines span {
    display: block;
    width: 100%;
    height: 1px;
    background: rgba(200, 146, 74, 0.06);
  }
  .final-cta__inner {
    position: relative;
    text-align: center;
  }
  .final-cta__headline {
    color: var(--color-cream);
    margin-bottom: 24px;
    max-width: 700px;
    margin-left: auto;
    margin-right: auto;
  }
  .final-cta__sub {
    color: var(--color-text-muted);
    max-width: 520px;
    margin: 0 auto;
  }

  /* ===== RESPONSIVE ===== */
  @media (max-width: 768px) {
    .hero {
      padding: 48px 0 64px;
    }
    .hero__inner {
      grid-template-columns: 1fr;
      gap: 48px;
    }
