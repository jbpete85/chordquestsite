---
import BaseLayout from '../layouts/BaseLayout.astro';
import FaqAccordion from '../components/FaqAccordion.astro';

const base = import.meta.env.BASE_URL;

const teacherFaqItems = [
  {
    question: 'Is ChordQuest really free for music teachers?',
    answer: 'Yes. Teachers download and use ChordQuest free, forever. There is no trial, no expiration, and no catch. Students pay a small monthly subscription — teachers never pay a cent.',
  },
  {
    question: 'What sheet music does ChordQuest work with?',
    answer: 'Any standard staff notation — Faber, Hal Leonard, Alfred, Suzuki, Henle, RCM, handwritten charts. ChordQuest reads directly from a photo of the page, so it works with any publisher and any edition.',
  },
  {
    question: 'Does ChordQuest replace my teaching method?',
    answer: "No. ChordQuest doesn't require a new curriculum, new workflow, or new repertoire. It works alongside whatever you already do — it just fixes what happens at home between lessons.",
  },
  {
    question: 'How do I share ChordQuest with my students?',
    answer: 'Send one link. Your students download the app, set up in seconds, and start hearing their music at home. One send covers your whole studio.',
  },
  {
    question: 'What makes ChordQuest different from other apps?',
    answer: 'Most sheet music apps require you to search their library and hope your song is in it. ChordQuest works from a photo of whatever sheet music you already have — any publisher, any instrument, instantly.',
  },
];

const features = [
  {
    title: 'Any sheet music',
    body: "ChordQuest reads directly from your student's sheet music. Whatever you assign, ChordQuest reads it. No library limitations.",
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="9" y1="13" x2="15" y2="13"/><line x1="9" y1="17" x2="13" y2="17"/></svg>`,
  },
  {
    title: '60 seconds to set up',
    body: 'Download the app. Point at sheet music. There is no onboarding process, no curriculum to configure.',
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>`,
  },
  {
    title: 'Nothing changes',
    body: "Your repertoire stays yours. Your methods stay yours. ChordQuest doesn't replace your teaching, it works alongside it.",
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>`,
  },
  {
    title: 'Free for you. Forever.',
    body: 'Teachers download free. Students pay a small subscription. We never charge you for it.',
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>`,
  },
  {
    title: 'Any instrument',
    body: 'Standard staff notation for piano and guitar, and dozens of other instruments.',
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M9 18V5l12-2v13"/><circle cx="6" cy="18" r="3"/><circle cx="18" cy="16" r="3"/></svg>`,
  },
  {
    title: 'Share with your class',
    body: 'Send one link to your students. They download, set up in seconds, and start hearing their music at home.',
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M4 12v8a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2v-8"/><polyline points="16 6 12 2 8 6"/><line x1="12" y1="2" x2="12" y2="15"/></svg>`,
  },
];
---
<BaseLayout title="For Teachers — ChordQuest" description="Free for music teachers forever. Give every student instant playback of their exact part from any sheet music." hideContactForm={true}>

  <!-- ===== HERO ===== -->
  <section class="t-hero">
    <div class="container container--narrow t-hero__inner">
      <p class="eyebrow">For Music Teachers</p>
      <h1 class="headline-xl t-hero__headline">You teach the music. Let ChordQuest take care of the practice.</h1>
      <p class="body-lg t-hero__sub">Your students hear their exact part from any piece of sheet music before or after the lesson, so you spend your time teaching expression, technique, and musicality instead of re-teaching notes.</p>
      <a href="#contact" class="btn btn--gold">Teachers Download Free</a>
    </div>
  </section>

  <!-- ===== FEATURE GRID ===== -->
  <section class="features section">
    <div class="container">
      <h2 class="headline-lg features__headline">Built around how you actually work.</h2>
      <div class="features__grid">
        {features.map((f) => (
          <div class="feature-card" tabindex="0">
            <div class="feature-card__icon" set:html={f.icon} />
            <h3 class="feature-card__title">{f.title}</h3>
            <p class="feature-card__body">{f.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ===== TEACHER FAQ ===== -->
  <section class="t-faq section" id="faq">
    <div class="container container--narrow">
      <h2 class="headline-md t-faq__headline">Questions teachers ask.</h2>
      <FaqAccordion items={teacherFaqItems} />
    </div>
  </section>

  <!-- ===== CLOSING ===== -->
  <section class="t-closing section">
    <div class="container container--narrow t-closing__inner">
      <p class="eyebrow">The Last Thing</p>
      <h2 class="headline-lg t-closing__headline">Don't change how you teach.</h2>
      <p class="t-closing__subline">Change what happens between lessons.</p>
      <p class="body-lg t-closing__body">ChordQuest isn't a replacement for the magic that happens in the classroom. It's a tool to keep your students invested in their musical journey with you.</p>
      <a href="#contact" class="btn btn--gold">Teachers Download Free</a>
    </div>
  </section>

  <!-- ===== TEACHER CONTACT FORM ===== -->
  <section class="contact section" id="contact">
    <div class="container container--narrow">
      <p class="eyebrow">Free Forever for Teachers</p>
      <h2 class="headline-lg contact__headline">Claim Your Free ChordQuest License Today</h2>
      <p class="body-md contact__sub">Tell us about your studio and we'll reach out to get you set up.</p>
      <form class="contact__form" action="https://formsubmit.co/hello@chordquestmusic.com" method="POST">
        <input type="hidden" name="_subject" value="Teacher Free License Request">
        <input type="hidden" name="_captcha" value="false">
        <input type="hidden" name="_next" value="https://jbpete85.github.io/chordquestsite/teachers">
        <div class="contact__row">
          <div class="contact__field">
            <label for="contact-name" class="contact__label">Name</label>
            <input type="text" id="contact-name" name="name" required class="contact__input" placeholder="Your name">
          </div>
          <div class="contact__field">
            <label for="contact-email" class="contact__label">Email</label>
            <input type="email" id="contact-email" name="email" required class="contact__input" placeholder="you@email.com">
          </div>
        </div>
        <div class="contact__field">
          <label for="contact-students" class="contact__label">How many students do you teach? <span style="font-weight:400; opacity:0.6">(optional)</span></label>
          <select id="contact-students" name="students" class="contact__input contact__select">
            <option value="">Select one</option>
            <option value="1-5">1–5 students</option>
            <option value="6-15">6–15 students</option>
            <option value="16-30">16–30 students</option>
            <option value="30+">30+ students</option>
          </select>
        </div>
        <button type="submit" class="btn btn--gold contact__submit">Request Free Access</button>
      </form>
    </div>
  </section>
</BaseLayout>

<style>
  /* ===== HERO ===== */
  .t-hero {
    background-color: var(--color-dark);
    padding: 96px 0 112px;
    text-align: center;
  }
  .t-hero__headline {
    color: var(--color-cream);
    margin-bottom: 24px;
    max-width: 720px;
    margin-left: auto;
    margin-right: auto;
  }
  .t-hero__sub {
    color: var(--color-text-muted);
    margin-bottom: 40px;
    max-width: 600px;
    margin-left: auto;
    margin-right: auto;
  }

  /* ===== FEATURES (gold tiles with icons) ===== */
  .features {
    background-color: var(--color-cream);
  }
  .features__headline {
    text-align: center;
    margin-bottom: 56px;
  }
  .features__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
  }
  .feature-card {
    background: linear-gradient(145deg, rgba(200, 146, 74, 0.08), rgba(200, 146, 74, 0.03));
    border: 1px solid rgba(200, 146, 74, 0.2);
    border-radius: 16px;
    padding: 36px 32px;
    transition: transform 0.3s ease, box-shadow 0.3s ease, border-color 0.3s ease;
    cursor: default;
    outline: none;
  }
  .feature-card:hover,
  .feature-card:focus-visible {
    transform: translateY(-4px);
    border-color: var(--color-gold);
    box-shadow: 0 12px 40px rgba(200, 146, 74, 0.12);
  }
  .feature-card__icon {
    width: 36px;
    height: 36px;
    margin-bottom: 20px;
    color: var(--color-gold);
  }
  .feature-card__icon svg {
    width: 100%;
    height: 100%;
  }
  .feature-card__title {
    font-family: var(--font-headline);
    font-size: 20px;
    color: var(--color-dark);
    margin-bottom: 12px;
  }
  .feature-card__body {
    font-size: 15px;
    line-height: 1.7;
    color: var(--color-text-warm);
  }

  /* ===== TEACHER FAQ ===== */
  .t-faq {
    background-color: var(--color-cream);
  }
  .t-faq__headline {
    margin-bottom: 40px;
  }

  /* ===== CLOSING ===== */
  .t-closing {
    background-color: var(--color-dark);
    text-align: center;
  }
  .t-closing__inner {
    max-width: 640px;
  }
  .t-closing__headline {
    color: var(--color-cream);
    margin-bottom: 8px;
  }
  .t-closing__subline {
    font-family: var(--font-headline);
    font-style: italic;
    font-size: 32px;
    line-height: 1.2;
    color: var(--color-gold);
    margin-bottom: 28px;
  }
  .t-closing__body {
    color: var(--color-text-muted);
    margin-bottom: 40px;
  }

  /* ===== TEACHER CONTACT FORM (cream — matches home page) ===== */
  .contact {
    background-color: var(--color-card-bg);
    padding: 100px 0;
  }
  .contact__headline {
    margin-top: 12px;
  }
  .contact__sub {
    color: var(--color-text-warm);
    margin-top: 12px;
    margin-bottom: 40px;
  }
  .contact__form {
    display: flex;
    flex-direction: column;
    gap: 20px;
    max-width: 600px;
  }
  .contact__row {
    display: flex;
    gap: 20px;
  }
  .contact__field {
    display: flex;
    flex-direction: column;
    gap: 6px;
    flex: 1;
  }
  .contact__label {
    font-family: var(--font-body);
    font-size: 13px;
    font-weight: 500;
    color: var(--color-text-muted);
    letter-spacing: 0.02em;
  }
  .contact__input {
    font-family: var(--font-body);
    font-size: 15px;
    color: var(--color-dark);
    background-color: var(--color-white);
    border: 1px solid var(--color-border-light);
    border-radius: 8px;
    padding: 12px 16px;
    transition: border-color 0.2s ease;
    outline: none;
    width: 100%;
  }
  .contact__input::placeholder {
    color: var(--color-text-muted);
    opacity: 0.6;
  }
  .contact__input:focus {
    border-color: var(--color-gold);
  }
  .contact__select {
    appearance: none;
    background-image: url("data:image/svg+xml,%3Csvg width='12' height='8' viewBox='0 0 12 8' fill='none' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M1 1.5L6 6.5L11 1.5' stroke='%238A7260' stroke-width='1.5' stroke-linecap='round' stroke-linejoin='round'/%3E%3C/svg%3E");
    background-repeat: no-repeat;
    background-position: right 16px center;
    padding-right: 40px;
    cursor: pointer;
  }
  .contact__submit {
    align-self: flex-start;
    margin-top: 8px;
    cursor: pointer;
    border: none;
  }

  /* ===== RESPONSIVE ===== */
  @media (max-width: 768px) {
    .t-hero {
      padding: 64px 0 80px;
    }
    .features__grid {
      grid-template-columns: 1fr;
    }
    .contact__row {
      flex-direction: column;
    }
  }
</style>
