---
import BaseLayout from '../layouts/BaseLayout.astro';
import FaqAccordion from '../components/FaqAccordion.astro';

const base = import.meta.env.BASE_URL;

const parentFaqItems = [
  {
    question: 'How much does it cost?',
    answer: "The app is free to download. Students access full features with a small monthly subscription. Your child's teacher uses ChordQuest free.",
  },
  {
    question: 'What devices does it work on?',
    answer: 'iPhone and iPad running iOS 16 or later. An Android version is planned.',
  },
  {
    question: 'Does it work with any sheet music?',
    answer: "ChordQuest works best with clearly printed, standard notation from any publisher. If your teacher assigns it, ChordQuest can play it back.",
  },
  {
    question: 'Can my child isolate just their part?',
    answer: 'Yes. They can mute and hear different staves independently — perfect for focusing on exactly what they need to practice.',
  },
  {
    question: 'Does my child need an account?',
    answer: 'They can try it immediately without creating an account. A simple sign-up is required for the full subscription.',
  },
  {
    question: 'Is this a replacement for lessons?',
    answer: "No. ChordQuest helps students practice between lessons. It makes their teacher's instruction more effective — not less necessary.",
  },
  {
    question: 'What if the playback sounds wrong?',
    answer: 'It may be a recognition issue. Try uploading the score again or using a clearer photo. Accuracy continues to improve with every update.',
  },
];
---
<BaseLayout title="For Parents — ChordQuest" description="Your teacher recommended ChordQuest. Practice goes from hard to fun when they know what their music is supposed to sound like.">

  <!-- ===== HERO ===== -->
  <section class="p-hero">
    <div class="container container--narrow p-hero__inner">
      <p class="eyebrow">Your teacher recommended ChordQuest</p>
      <h1 class="headline-xl p-hero__headline">The kids who stick with it are the ones who feel like they get it.</h1>
      <p class="body-lg p-hero__sub">Practice goes from hard to fun when they know what their music is supposed to sound like. ChordQuest reads their sheet music, then plays their exact part from any piece of music. No musical knowledge required from parents.</p>
      <a href="https://app.chordquestmusic.com" class="btn btn--gold">Download on App Store</a>
    </div>
  </section>

  <!-- ===== THE RESEARCH ===== -->
  <section class="p-science section">
    <div class="container">
      <div class="p-science__header">
        <h2 class="headline-md p-science__headline">The research is clear.</h2>
        <p class="body-lg text-warm p-science__sub">Hearing music played back before practicing changes how kids learn.</p>
      </div>
      <div class="p-science__grid">
        <div class="p-science__card">
          <span class="p-science__number" data-target="2.3" data-suffix="×" data-decimals="1">0</span>
          <p class="p-science__label">better retention overnight when kids hear their music first</p>
          <cite class="p-science__cite">Cash et al., 2014</cite>
        </div>
        <div class="p-science__card">
          <span class="p-science__number p-science__number--static">#1</span>
          <p class="p-science__label">Hearing a model beat every other method tested — including verbal instruction</p>
          <cite class="p-science__cite">Rosenthal, 1984</cite>
        </div>
        <div class="p-science__card">
          <span class="p-science__number" data-target="100" data-suffix="%" data-decimals="0">0</span>
          <p class="p-science__label">of grade levels K–4 showed significantly higher scores with listening familiarity</p>
          <cite class="p-science__cite">Frewen, 2010</cite>
        </div>
      </div>
      <p class="p-science__source">Based on peer-reviewed studies from the Journal of Research in Music Education</p>
    </div>
  </section>

  <!-- ===== HOW IT WORKS ===== -->
  <section class="p-how section">
    <div class="container">
      <div class="p-how__grid">
        <div class="p-how__card">
          <span class="p-how__num">1</span>
          <h3 class="p-how__title">Open the app</h3>
          <p class="p-how__body">Download ChordQuest on your iPhone or iPad or open the web app on your computer.</p>
        </div>
        <div class="p-how__card">
          <span class="p-how__num">2</span>
          <h3 class="p-how__title">Upload your music</h3>
          <p class="p-how__body">Take a picture of any sheet music or use our upload feature if it's a digital copy.</p>
        </div>
        <div class="p-how__card">
          <span class="p-how__num">3</span>
          <h3 class="p-how__title">Tap play</h3>
          <p class="p-how__body">Hear your exact part played back. Listen as many times as you need before practicing.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== PARENT FAQ ===== -->
  <section class="p-faq section" id="faq">
    <div class="container container--narrow">
      <h2 class="headline-md p-faq__headline">Questions you probably have.</h2>
      <p class="body-md text-warm p-faq__intro">Everything you need to know before your child downloads.</p>
      <FaqAccordion items={parentFaqItems} />
    </div>
  </section>

  <!-- ===== CLOSING ===== -->
  <section class="p-closing section">
    <div class="container container--narrow p-closing__inner">
      <h2 class="headline-lg p-closing__headline">Confidence is the goal. Yours and theirs.</h2>
      <p class="body-lg p-closing__body">Research shows that retention improves when kids can hear their music before they practice it. ChordQuest builds more confident students and empowers parents to support their musical journey.</p>
      <a href="https://app.chordquestmusic.com" class="btn btn--gold">Download ChordQuest Free</a>
    </div>
  </section>
</BaseLayout>

<style>
  /* ===== HERO ===== */
  .p-hero {
    background-color: var(--color-dark);
    padding: 96px 0 112px;
    text-align: center;
  }
  .p-hero__headline {
    color: var(--color-cream);
    margin-bottom: 24px;
    max-width: 720px;
    margin-left: auto;
    margin-right: auto;
  }
  .p-hero__sub {
    color: var(--color-text-muted);
    margin-bottom: 40px;
    max-width: 620px;
    margin-left: auto;
    margin-right: auto;
  }

  /* ===== THE RESEARCH ===== */
  .p-science {
    background-color: var(--color-card-bg);
    text-align: center;
  }
  .p-science__header {
    max-width: 620px;
    margin: 0 auto 48px;
  }
  .p-science__headline {
    margin-bottom: 12px;
  }
  .p-science__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 32px;
  }
  .p-science__card {
    background-color: var(--color-white);
    border: 1px solid var(--color-border-light);
    border-radius: 16px;
    padding: 40px 32px;
    opacity: 0;
    transform: translateY(16px);
    transition: opacity 0.5s ease, transform 0.5s ease, box-shadow 0.3s ease, border-color 0.3s ease;
    cursor: default;
  }
  .p-science.is-visible .p-science__card:nth-child(1) {
    opacity: 1; transform: translateY(0); transition-delay: 0s;
  }
  .p-science.is-visible .p-science__card:nth-child(2) {
    opacity: 1; transform: translateY(0); transition-delay: 0.12s;
  }
  .p-science.is-visible .p-science__card:nth-child(3) {
    opacity: 1; transform: translateY(0); transition-delay: 0.24s;
  }
  .p-science.is-visible .p-science__card:hover {
    transform: translateY(-4px);
    border-color: var(--color-gold);
    box-shadow: 0 12px 40px rgba(200, 146, 74, 0.12);
  }
  .p-science__number {
    display: block;
    font-family: var(--font-headline);
    font-size: 56px;
    line-height: 1;
    color: var(--color-gold);
    margin-bottom: 16px;
  }
  .p-science__label {
    font-size: 15px;
    line-height: 1.7;
    color: var(--color-text-warm);
    margin-bottom: 12px;
  }
  .p-science__cite {
    display: block;
    font-family: var(--font-mono);
    font-size: 11px;
    font-style: normal;
    color: var(--color-text-muted);
    letter-spacing: 0.02em;
  }
  .p-science__source {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--color-text-muted);
    margin-top: 40px;
    letter-spacing: 0.02em;
  }

  /* ===== HOW IT WORKS ===== */
  .p-how {
    background-color: var(--color-cream);
  }
  .p-how__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 32px;
  }
  .p-how__card {
    background-color: var(--color-white);
    border: 1px solid var(--color-border-light);
    border-radius: 16px;
    padding: 40px 32px;
  }
  .p-how__num {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    border-radius: 50%;
    background-color: var(--color-gold);
    color: var(--color-dark);
    font-family: var(--font-body);
    font-size: 15px;
    font-weight: 700;
    margin-bottom: 20px;
  }
  .p-how__title {
    font-family: var(--font-headline);
    font-size: 22px;
    margin-bottom: 12px;
    color: var(--color-dark);
  }
  .p-how__body {
    font-size: 15px;
    line-height: 1.7;
    color: var(--color-text-warm);
  }

  /* ===== FAQ ===== */
  .p-faq {
    background-color: var(--color-card-bg);
  }
  .p-faq__headline {
    margin-bottom: 8px;
  }
  .p-faq__intro {
    margin-bottom: 40px;
  }

  /* ===== CLOSING ===== */
  .p-closing {
    background-color: var(--color-dark);
    text-align: center;
  }
  .p-closing__inner {
    max-width: 640px;
  }
  .p-closing__headline {
    color: var(--color-cream);
    margin-bottom: 24px;
  }
  .p-closing__body {
    color: var(--color-text-muted);
    margin-bottom: 40px;
  }

  /* ===== RESPONSIVE ===== */
  @media (max-width: 768px) {
    .p-hero {
      padding: 64px 0 80px;
    }
    .p-science__grid {
      grid-template-columns: 1fr;
      gap: 24px;
    }
    .p-science__number {
      font-size: 40px;
    }
    .p-how__grid {
      grid-template-columns: 1fr;
    }
  }
</style>

<script>
  const section = document.querySelector('.p-science');
  if (section) {
    const numbers = section.querySelectorAll('.p-science__number[data-target]');
    let animated = false;

    const observer = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting && !animated) {
          animated = true;
          numbers.forEach((el) => animateNumber(el as HTMLElement));
          observer.unobserve(entry.target);
        }
      });
    }, { threshold: 0.3 });

    observer.observe(section);

    function animateNumber(el: HTMLElement) {
      const target = parseFloat(el.dataset.target!);
      const suffix = el.dataset.suffix || '';
      const decimals = parseInt(el.dataset.decimals || '0');
      const duration = 1500;
      const start = performance.now();

      function tick(now: number) {
        const elapsed = now - start;
        const progress = Math.min(elapsed / duration, 1);
        const eased = 1 - Math.pow(1 - progress, 3);
        const current = (target * eased).toFixed(decimals);
        el.textContent = current + suffix;
        if (progress < 1) requestAnimationFrame(tick);
      }
      requestAnimationFrame(tick);
    }
  }
</script>
