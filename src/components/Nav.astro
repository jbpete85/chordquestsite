---
const base = import.meta.env.BASE_URL;
---
<nav class="nav">
  <div class="nav__inner container">
    <a href={base} class="nav__logo"><img src={`${base}images/logo.png`} alt="ChordQuest" class="nav__logo-img" /></a>
    <div class="nav__links">
      <a href={`${base}teachers`} class="nav__link">For Teachers</a>
      <a href={`${base}parents`} class="nav__link">For Parents</a>
      <a href="#faq" class="nav__link">FAQ</a>
      <a href="#contact" class="nav__link">Contact</a>
      <a href="https://app.chordquestmusic.com" class="nav__link nav__login">Log In</a>
      <a href="https://app.chordquestmusic.com" class="btn btn--gold nav__cta">Download Free</a>
    </div>
    <button class="nav__hamburger" aria-label="Toggle menu" id="nav-toggle">
      <span></span>
      <span></span>
      <span></span>
    </button>
  </div>
  <div class="nav__mobile" id="nav-mobile">
    <a href={`${base}teachers`} class="nav__link">For Teachers</a>
    <a href={`${base}parents`} class="nav__link">For Parents</a>
    <a href="#faq" class="nav__link">FAQ</a>
    <a href="#contact" class="nav__link">Contact</a>
    <a href="https://app.chordquestmusic.com" class="nav__link nav__login">Log In</a>
    <a href="https://app.chordquestmusic.com" class="btn btn--gold nav__cta">Download Free</a>
  </div>
</nav>

<style>
  .nav {
    position: sticky;
    top: 0;
    z-index: 100;
    background-color: var(--color-dark);
    border-bottom: 2px solid var(--color-gold);
  }
  .nav__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 140px;
  }
  .nav__logo {
    display: flex;
    align-items: center;
    text-decoration: none;
  }
  .nav__logo-img {
    height: 160px;
    width: auto;
  }
  .nav__links {
    display: flex;
    align-items: center;
    gap: 32px;
  }
  .nav__link {
    font-family: var(--font-body);
    font-size: 14px;
    font-weight: 500;
    color: var(--color-text-muted);
    text-decoration: none;
    transition: color 0.2s ease;
  }
  .nav__link:hover {
    color: var(--color-cream);
  }
  .nav__cta {
    padding: 10px 22px;
    font-size: 14px;
  }
  .nav__hamburger {
    display: none;
    flex-direction: column;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 4px;
  }
  .nav__hamburger span {
    display: block;
    width: 22px;
    height: 2px;
    background-color: var(--color-cream);
    border-radius: 1px;
    transition: all 0.2s ease;
  }
  .nav__mobile {
    display: none;
    flex-direction: column;
    gap: 16px;
    padding: 16px 24px 24px;
    background-color: var(--color-dark);
    border-top: 1px solid var(--color-border-dark);
  }
  .nav__mobile .nav__cta {
    text-align: center;
  }

  @media (max-width: 768px) {
    .nav__links {
      display: none;
    }
    .nav__hamburger {
      display: flex;
    }
    .nav__mobile.is-open {
      display: flex;
    }
  }
</style>

<script>
  const toggle = document.getElementById('nav-toggle');
  const mobile = document.getElementById('nav-mobile');
  toggle?.addEventListener('click', () => {
    mobile?.classList.toggle('is-open');
  });
</script>
